    "declaration": false,
    "declarationMap": false,
    "outDir": "dist",
    "paths": {
      "react-dom": ["../../node_modules/preact/compat/src/index.d.ts"],
      "react": ["../../node_modules/preact/compat/src/index.d.ts"],
      "react/jsx-runtime": ["../../node_modules/preact/jsx-runtime/src/index.d.ts"]
    },
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "extends": "@mrpelz/boilerplate-preact/tsconfig.json",
  "include": ["src/**/*"]
}
